{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Agent(*)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "WebSearch",
      "WebFetch",
      "Read(*)",
      "Grep(*)",
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "PowerShell(*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/krien/github/software_claude_team/.claude/hooks/guard_main_branch.py",
            "statusMessage": "Checking branch protection..."
          },
          {
            "type": "command",
            "command": "python C:/Users/krien/github/software_claude_team/.claude/hooks/validate_commit_msg.py",
            "statusMessage": "Validating commit message format..."
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/krien/github/software_claude_team/.claude/hooks/guard_main_branch.py",
            "statusMessage": "Checking branch protection..."
          },
          {
            "type": "command",
            "command": "python C:/Users/krien/github/software_claude_team/.claude/hooks/validate_commit_msg.py",
            "statusMessage": "Validating commit message format..."
          }
        ]
      }
    ]
  }
}
